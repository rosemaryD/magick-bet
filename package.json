{
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test:devnet": "ts-node tests/devnet-integration.ts",
    "smoke:frontend": "npm --prefix app run smoke:build",
    "smoke:anchor": "anchor build",
    "smoke:devnet": "npm run test:devnet",
    "smoke:all": "npm run smoke:frontend && npm run smoke:anchor"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.0"
  },
  "devDependencies": {
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "ts-mocha": "^10.0.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "@types/node": "^18.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "prettier": "^2.6.2"
  }
}
